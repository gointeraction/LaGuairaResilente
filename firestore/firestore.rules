rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email != null && request.auth.token.email.lower() == 'bbmintellegent@gmail.com';
    }

    function isAdmin() {
      return (isAuthenticated() && getUserRole() == 'ADMIN') || isSuperAdmin();
    }
    
    function isCoordinator() {
      return isAuthenticated() && getUserRole() == 'COORDINATOR';
    }
    
    function isTrainer() {
      return isAuthenticated() && getUserRole() == 'TRAINER';
    }
    
    function isStudent() {
      return isAuthenticated() && getUserRole() == 'STUDENT';
    }
    
    function isSponsor() {
      return isAuthenticated() && getUserRole() == 'SPONSOR';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isApproved() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_approved == true;
    }

    function isCoordinatorOrAdmin() {
      return isCoordinator() || isAdmin();
    }

    function isStaff() {
      return isAdmin() || isTrainer() || isCoordinator();
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Subcollection: user_activity_log
      match /activity_log/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if true;
        allow update, delete: if false;
      }
    }

    // ============================================
    // TRACKS COLLECTION
    // ============================================
    match /tracks/{trackId} {
      allow read: if true;
      allow write: if isAdmin() || isTrainer();
    }

    // ============================================
    // COURSES COLLECTION
    // ============================================
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() || isTrainer();
    }

    // ============================================
    // ENROLLMENTS COLLECTION
    // ============================================
    match /enrollments/{enrollmentId} {
      allow read: if isStaff()
                  || (isStudent() && resource.data.student_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.student_id == request.auth.uid;
      allow update: if isStaff()
                    || (isStudent() && resource.data.student_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================
    // QUIZ SUBMISSIONS COLLECTION
    // ============================================
    match /quiz_submissions/{submissionId} {
      allow read: if isStaff()
                  || (isStudent() && resource.data.student_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.student_id == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ============================================
    // POINTS TRANSACTIONS COLLECTION
    // ============================================
    match /points_transactions/{txId} {
      allow read: if isStaff()
                  || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isAdmin() || isStaff();
      allow update, delete: if false;
    }

    // Legacy collection name compatibility
    match /resilience_points/{pointId} {
      allow read: if isStaff()
                  || (isStudent() && resource.data.student_id == request.auth.uid);
      allow create: if isAdmin() || isStaff();
      allow update, delete: if false;
    }

    // ============================================
    // CAMPS COLLECTION
    // ============================================
    match /camps/{campId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // WIFI NODES COLLECTION (code uses wifi_nodes)
    // ============================================
    match /wifi_nodes/{nodeId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // PSYCHOLOGISTS COLLECTION
    // ============================================
    match /psychologists/{psyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // RESILIENCE ACTIVITIES (menu catalog)
    // ============================================
    match /resilienceActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isTrainer();
      allow update: if isAdmin() || isTrainer();
      allow delete: if isAdmin();
    }

    // ============================================
    // RESILIENCE: EMOTIONAL CANVAS
    // ============================================
    match /resilience_emotional_canvas/{entryId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStudent() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isStudent() && resource.data.user_id == request.auth.uid);
    }

    // ============================================
    // RESILIENCE: MY GIFTS
    // ============================================
    match /resilience_my_gifts/{entryId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStudent() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isStudent() && resource.data.user_id == request.auth.uid);
    }

    // ============================================
    // RESILIENCE: DAILY JOURNAL
    // ============================================
    match /resilience_journal/{entryId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStudent() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isStudent() && resource.data.user_id == request.auth.uid);
    }

    // ============================================
    // RESILIENCE: MINDFULNESS
    // ============================================
    match /resilience_mindfulness/{entryId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStudent() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isStudent() && resource.data.user_id == request.auth.uid);
    }

    // ============================================
    // RESILIENCE: ACTION PLANS
    // ============================================
    match /resilience_action_plans/{planId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStudent() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || (isStudent() && resource.data.user_id == request.auth.uid);
    }

    // ============================================
    // RESILIENCE: APA ASSESSMENTS
    // ============================================
    match /resilience_apa_assessments/{assessmentId} {
      allow read: if isStaff() || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ============================================
    // DELIVERIES COLLECTION
    // ============================================
    match /deliveries/{deliveryId} {
      allow read: if isStaff();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // DISTRIBUTION ROUTES
    // ============================================
    match /distribution_routes/{routeId} {
      allow read: if isStaff();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // FOOD DISTRIBUTIONS
    // ============================================
    match /food_distributions/{distId} {
      allow read: if isStaff();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // MOBILE TOPUPS
    // ============================================
    match /mobile_topups/{topupId} {
      allow read: if isStaff();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // SPONSORS COLLECTION
    // ============================================
    match /sponsors/{sponsorId} {
      allow read: if isOwner(sponsorId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == sponsorId;
      allow update: if isOwner(sponsorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // SPONSORSHIPS COLLECTION
    // ============================================
    match /sponsorships/{sponsorshipId} {
      allow read: if isAuthenticated() && (
                    resource.data.sponsor_id == request.auth.uid 
                    || isCoordinatorOrAdmin()
                  );
      allow create: if isSponsor() && request.resource.data.sponsor_id == request.auth.uid;
      allow update: if isSponsor() && resource.data.sponsor_id == request.auth.uid
                    || isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // SPONSOR MATCHES (algorithm results)
    // ============================================
    match /sponsor_matches/{matchId} {
      allow read: if isStaff() || isSponsor();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ============================================
    // BENEFICIARIES COLLECTION (Anonymous profiles)
    // ============================================
    match /beneficiaries/{beneficiaryId} {
      allow read: if isSponsor() || isCoordinatorOrAdmin();
      allow write: if isCoordinatorOrAdmin();
    }

    // ============================================
    // COMPANIES COLLECTION
    // ============================================
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isSponsor();
      allow update: if isAdmin() || (isSponsor() && resource.data.owner_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================
    // JOB OPPORTUNITIES COLLECTION
    // ============================================
    match /job_opportunities/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isSponsor() || isAdmin();
      allow update: if (isSponsor() && resource.data.company_id == request.auth.uid)
                    || isAdmin();
      allow delete: if (isSponsor() && resource.data.company_id == request.auth.uid)
                    || isAdmin();
    }

    // ============================================
    // EMPLOYMENTS COLLECTION
    // ============================================
    match /employments/{employmentId} {
      allow read: if isAuthenticated() && (
                    resource.data.graduate_id == request.auth.uid
                    || resource.data.company_id == request.auth.uid
                    || isCoordinatorOrAdmin()
                  );
      allow create: if isSponsor() || isAdmin();
      allow update: if isSponsor() || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // CENSUS SURVEYS COLLECTION
    // ============================================
    match /census_surveys/{surveyId} {
      allow read: if isCoordinatorOrAdmin();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // MILESTONES COLLECTION
    // ============================================
    match /milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.user_id);
      allow create: if isAdmin() || isStaff();
      allow update: if isOwner(resource.data.user_id);
      allow delete: if isOwner(resource.data.user_id) || isAdmin();
    }

    // ============================================
    // IMPACT METRICS COLLECTION
    // ============================================
    match /impact_metrics/{metricId} {
      allow read: if isStaff() || isSponsor();
      allow write: if false;
    }

    // ============================================
    // REDEMPTION CATALOG (items available for points)
    // ============================================
    match /redemption_catalog/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // USER REDEMPTIONS (redemption transactions)
    // ============================================
    match /user_redemptions/{redemptionId} {
      allow read: if isStaff()
                  || (isStudent() && resource.data.user_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ============================================
    // CERTIFICATES COLLECTION
    // ============================================
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // GAME SESSIONS COLLECTION
    // ============================================
    match /game_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ============================================
    // COORDINATION: EVENTS (code uses coordination_events)
    // ============================================
    match /coordination_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // COORDINATION: MEETINGS (code uses coordination_meetings)
    // ============================================
    match /coordination_meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // SHELTERS COLLECTION
    // ============================================
    match /shelters/{shelterId} {
      allow read: if isAuthenticated();
      allow create: if isCoordinatorOrAdmin();
      allow update: if isCoordinatorOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // SUPPORT NETWORK REGISTRATIONS
    // ============================================
    match /support_network_registrations/{regId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ============================================
    // REPORTS CATALOG
    // ============================================
    match /reports/{reportId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ============================================
    // POINTS CATALOG (legacy name compatibility)
    // ============================================
    match /points_catalog/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
