# ============================================
# LA GUAIRA RESILIENTE DIGITAL - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# Firebase Configuration
# ============================================
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=la-guaira-resiliente.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=la-guaira-resiliente
VITE_FIREBASE_STORAGE_BUCKET=la-guaira-resiliente.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ============================================
# Firebase Emulators (Development)
# ============================================
# Uncomment these to use Firebase Emulators locally
# VITE_FIREBASE_EMULATOR_AUTH=http://localhost:9099
# VITE_FIREBASE_EMULATOR_FIRESTORE=localhost:8080
# VITE_FIREBASE_EMULATOR_STORAGE=localhost:9199
# VITE_FIREBASE_EMULATOR_FUNCTIONS=localhost:5001

# ============================================
# Games Server
# ============================================
VITE_GAMES_SERVER_URL=http://localhost:3001
VITE_GAMES_SERVER_WS_URL=ws://localhost:3001

# ============================================
# App Configuration
# ============================================
VITE_APP_NAME=La Guaira Resiliente Digital
VITE_APP_VERSION=1.2.0
VITE_APP_ENV=development

# ============================================
# Email Configuration (Cloud Functions)
# ============================================
# SMTP settings for transactional emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@laguairaresiliente.gob.ve
SMTP_PASS=your-smtp-password
EMAIL_FROM=La Guaira Resiliente <noreply@laguairaresiliente.gob.ve>

# ============================================
# External Services (Optional)
# ============================================
# Twilio for SMS (optional)
# TWILIO_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE=+1234567890

# Google Maps API (for coverage map)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Security
# ============================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT Secret (for custom tokens if needed)
# JWT_SECRET=your-jwt-secret-key
